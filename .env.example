# =====================================================================
# MineWatch - example env file consumed by docker-compose.
# DO NOT commit your real values.  Copy this to `.env` next to
# `docker-compose.yml` and fill in your secrets.
# =====================================================================

# --- WhatsApp target (REQUIRED for normal daemon mode) ---
# Group JID:  1203630xxxxxxxxx@g.us
# Don't know your JID yet?  Skip this for now and set
# LIST_GROUPS_ON_START=true below to discover it.  In list-groups
# mode WHATSAPP_GROUP_JID is NOT required.
WHATSAPP_GROUP_JID=

# --- Group JID discovery (one-shot, daemon exits after running) ---
# Set to `true` to make the daemon log every group the connected
# WhatsApp account is a member of, then exit.  Copy the JID of your
# target group into WHATSAPP_GROUP_JID above, unset this flag, and
# restart the daemon normally.
# Default: false.
LIST_GROUPS_ON_START=false

# Optional: when LIST_GROUPS_ON_START=true, only print the FIRST
# group whose subject contains this substring (case-insensitive)
# and exit.  Useful in CI / auto-deploy scripts that want a
# single deterministic JID line in the logs.
GROUP_MATCH_KEYWORD=

# --- Minecraft server ---
# If using CasaOS + network_mode: host, 127.0.0.1 hits the host's MC
# server directly.
MC_HOST=127.0.0.1
MC_PORT=25565

# RCON is optional.  Enable in server.properties:
#   enable-rcon=true
#   rcon.port=25575
#   rcon.password=changeme
MC_RCON_PORT=25575
MC_RCON_PASSWORD=

# Absolute path to the server's latest.log on the HOST.
# For a CasaOS-installed MC server this is usually:
#   /DATA/Minecraft/logs/latest.log
# For a bare-metal install:  /opt/minecraft/logs/latest.log  (or similar)
MC_LOG_PATH=/DATA/Minecraft/logs/latest.log

# --- Thresholds ---
POLL_INTERVAL_MS=5000
LATENCY_INTERVAL_MS=10000
PING_THRESHOLD_MS=150
DOWN_FAIL_COUNT=3
HIGH_PING_FAIL_COUNT=3
TPS_THRESHOLD=18.0
LOG_LEVEL=info
