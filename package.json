{
  "name": "minewatch",
  "version": "1.0.0",
  "description": "Minecraft-to-WhatsApp monitoring daemon. Watches a self-hosted Minecraft Java server (state, latency, TPS, player sessions) and pushes alerts to a WhatsApp group via the WhatsApp Web multi-device protocol.",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "minecraft",
    "whatsapp",
    "monitoring",
    "daemon",
    "rcon",
    "baileys"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
"dependencies": {
    "@whiskeysockets/baileys": "^6.7.0",
    "dotenv": "^16.4.5",
    "minecraft-server-util": "^5.0.0",
    "pino": "^9.4.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/qrcode": "^1.5.5",
    "pino-pretty": "^11.2.2",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
